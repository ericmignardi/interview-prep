{
  "compilerOptions": {
    "strict": true,
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    "lib": ["ES2020", "DOM", "DOM.Iterable"]
  },
  "include": [
    "frontend/code-challenges/**/*.ts",
    "frontend/code-challenges/**/*.tsx",
    "fullstack/code-challenges/**/*.ts",
    "fullstack/code-challenges/**/*.tsx"
  ]
}
